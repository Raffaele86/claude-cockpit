{
  "name": "claude-cockpit",
  "version": "0.13.0",
  "private": true,
  "description": "Claude Cockpit — pilota Claude Code da un'app desktop",
  "author": "Raffaele",
  "main": "electron/main.cjs",
  "scripts": {
    "sync-protocol": "cp ../engine/src/protocol.ts src/protocol.ts",
    "dev:vite": "vite",
    "build:renderer": "vite build",
    "dist:win": "vite build && electron-builder --win --config electron-builder.yml",
    "dist:win:installer": "vite build && electron-builder --win nsis --config electron-builder.yml",
    "dev": "concurrently -k -n vite,electron \"vite\" \"wait-on tcp:127.0.0.1:5173 && cross-env COCKPIT_RENDERER_URL=http://127.0.0.1:5173 electron . --no-sandbox\"",
    "electron": "electron . --no-sandbox"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "43.0.0",
    "electron-builder": "^26.15.3",
    "marked": "^14.1.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.1"
  }
}
